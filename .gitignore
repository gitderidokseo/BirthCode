# Build artifacts
build/
.gradle/
app/build/
functions/lib/
functions/node_modules/

# Android SDK local settings
local.properties

# IntelliJ / Android Studio settings
.idea/
*.iml
*.iws
*.ipr
out/

# Firebase / Functions
.firebase/
firebase-debug.log*
firestore-debug.log*
pubsub-debug.log*
ui-debug.log*
functions/.env
functions/.runtimeconfig.json

# Operating System files
.DS_Store
Thumbs.db
desktop.ini

# Signing keys (CRITICAL: NEVER COMMIT THESE)
*.jks
*.keystore
keystore/
keystore.properties

# Profiling / Capture files
captures/
*.hprof

# Code coverage reports
*.exec

# Output files
*.apk
*.aab
*.ap_
*.ipa

# iOS (Codemagic regenerates the Xcode project from ios/project.yml via
# `xcodegen generate`, and syncs ios/Resources/Web from app/src/main/assets
# at build time — neither should be committed)
ios/*.xcodeproj/
ios/Resources/Web/
ios/DerivedData/

# Logs
lint/
*.log

